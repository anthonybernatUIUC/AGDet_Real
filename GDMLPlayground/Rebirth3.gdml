    <volume name="worldVOL">
      <materialref ref="G4_Galactic"/>
      <solidref ref="WorldBox"/>

      <!-- <physvol name="PV_AlCap1">
        <volumeref ref="AlCap"/>
        <position name="P-AlCap1" unit="mm" x="-0.6428*AlDist" z="0.766*AlDist"/>
        <rotation name="R-AlCap1" unit="deg" y="40"/>
      </physvol>
      <physvol name="PV_AlCap2"> 
        <volumeref ref="AlCap"/>
        <position name="P-AlCap2" unit="mm" x="AlDist*0.3214" y="AlDist*-0.5567" z="AlDist*0.766"/>
        <rotation name="R-AlCap2" unit="deg" x="-36.00521482" y="-18.74723725" z="-113.8586548"/>
      </physvol>
      <physvol name="PV_AlCap3"> 
        <volumeref ref="AlCap"/>
        <position name="P-AlCap3" unit="mm" x="AlDist*0.3214" y="AlDist*0.5567" z="AlDist*0.766"/>
        <rotation name="R-AlCap3" unit="deg" x="36.00521482" y="-18.74723725" z="113.8586548"/>
      </physvol>
      <physvol name="PV_AlCap4"> 
        <volumeref ref="AlCap"/>
        <position name="P-AlCap4" unit="mm" x="0.6428*AlDist" z="-0.766*AlDist"/>
        <rotation name="R-AlCap4" unit="deg" y="-140"/>
      </physvol>
      <physvol name="PV_AlCap5"> 
        <volumeref ref="AlCap"/>
        <position name="P-AlCap5" unit="mm" x="AlDist*-0.3214" y="AlDist*0.5567" z="AlDist*-0.766"/>
        <rotation name="R-AlCap5" unit="deg" x="143.99478518" y="18.74723725" z="66.1413452"/>
      </physvol>
